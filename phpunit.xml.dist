<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/9.3/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
         processIsolation="false"
         stopOnFailure="false">
    <testsuites>
        <testsuite name="HuPHP Tests">
            <directory suffix="Test.php">tests</directory>
            <exclude>tests/Database/DatabaseMSSQLTest.php</exclude>
            <exclude>tests/Database/DatabaseOperatorsTest.php</exclude>
            <exclude>tests/Database/DatabaseSettingsMSSQLTest.php</exclude>
            <exclude>tests/Database/DatabaseSettingsMySQLTest.php</exclude>
            <exclude>tests/Database/DatabaseSettingsTest.php</exclude>
            <exclude>tests/Database/DatabaseSqliteTest.php</exclude>
            <exclude>tests/Database/IDatabaseTest.php</exclude>
            <exclude>tests/Exceptions/BaseExceptionTest.php</exclude>
            <exclude>tests/Exceptions/Filesystem/FileExceptionTest.php</exclude>
            <exclude>tests/Exceptions/Database/DatabaseExceptionTest.php</exclude>
            <exclude>tests/Exceptions/Network/</exclude>
            <exclude>tests/Exceptions/Strings/</exclude>
            <exclude>tests/Exceptions/Variables/VariableExceptionsTest.php</exclude>
            <exclude>tests/Exceptions/Variables/VariableEmptyExceptionTest.php</exclude>
            <exclude>tests/System/Console/</exclude>
            <exclude>tests/User/UserBaseTest.php</exclude>
        </testsuite>
    </testsuites>

    <coverage>
        <include>
            <directory suffix=".php">./Database</directory>
            <directory suffix=".php">./Debug</directory>
            <directory suffix=".php">./Exceptions</directory>
            <directory suffix=".php">./Filesystem</directory>
            <directory suffix=".php">./images</directory>
            <directory suffix=".php">./RegExp</directory>
            <directory suffix=".php">./System</directory>
            <directory suffix=".php">./User</directory>
            <directory suffix=".php">./Vars</directory>
        </include>
        <exclude>
            <directory suffix=".php">./Database/DatabaseMSSQL.php</directory>
            <directory suffix=".php">./Database/DatabaseSettingsMSSQL.php</directory>
        </exclude>
        <report>
            <html outputDirectory="build/coverage"/>
            <text outputFile="build/coverage.txt" showUncoveredFiles="true"/>
        </report>
    </coverage>
</phpunit>