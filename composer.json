{
    "name": "hubbitus/huphp",
    "description": "Modern PHP framework supporting PHP 8.0+ for common tasks like dumps, logging and so on",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Hubbitus Framework",
            "email": "Pahan@Hubbitus.info"
        }
    ],
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpdocumentor/phpdocumentor": "^3.0",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Hubbitus\\HuPHP\\": "./"
        },
        "files": [
            "HuPHP.autoload.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Hubbitus\\HuPHP\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "tests/run-tests.sh",
        "phpstan": "phpstan analyse",
        "clean": "rm -rvf .phpunit.result.cache .tools/regenerate.all.log .tools/Packages/build/* build/* .phpunit.result.cache *.log",
        "build": "echo 'Build completed'"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
