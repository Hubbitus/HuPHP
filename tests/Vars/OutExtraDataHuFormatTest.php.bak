<?php
declare(strict_types=1);

namespace Hubbitus\Tests\HuPHP\Vars;

use Hubbitus\HuPHP\Vars\OutExtraDataHuFormat;
use PHPUnit\Framework\TestCase;

class OutExtraDataHuFormatTest extends TestCase
{
	public function testConstructor(): void
	{
		$var = ['test' => 'value'];
		$format = [
			'FORMAT_CONSOLE' => 'Console: %s',
			'FORMAT_WEB' => 'Web: %s',
			'FORMAT_FILE' => 'File: %s',
		];
		$out = new OutExtraDataHuFormat($var, $format);
		$this->assertInstanceOf(OutExtraDataHuFormat::class, $out);
	}

	public function testStrToConsole(): void
	{
		$var = ['test' => 'value'];
		$format = [
			'FORMAT_CONSOLE' => 'Console: %s',
			'FORMAT_WEB' => 'Web: %s',
			'FORMAT_FILE' => 'File: %s',
		];
		$out = new OutExtraDataHuFormat($var, $format);
		$result = $out->strToConsole();
		$this->assertIsString($result);
		$this->assertStringContainsString('Console:', $result);
	}

	public function testStrToFile(): void
	{
		$var = ['test' => 'value'];
		$format = [
			'FORMAT_CONSOLE' => 'Console: %s',
			'FORMAT_WEB' => 'Web: %s',
			'FORMAT_FILE' => 'File: %s',
		];
		$out = new OutExtraDataHuFormat($var, $format);
		$result = $out->strToFile();
		$this->assertIsString($result);
		$this->assertStringContainsString('File:', $result);
	}

	public function testStrToWeb(): void
	{
		$var = ['test' => 'value'];
		$format = [
			'FORMAT_CONSOLE' => 'Console: %s',
			'FORMAT_WEB' => 'Web: %s',
			'FORMAT_FILE' => 'File: %s',
		];
		$out = new OutExtraDataHuFormat($var, $format);
		$result = $out->strToWeb();
		$this->assertIsString($result);
		$this->assertStringContainsString('Web:', $result);
	}

	public function testStrToConsoleWithCustomFormat(): void
	{
		$var = ['test' => 'value'];
		$format = [
			'FORMAT_CONSOLE' => 'Console: %s',
			'FORMAT_WEB' => 'Web: %s',
			'FORMAT_FILE' => 'File: %s',
		];
		$out = new OutExtraDataHuFormat($var, $format);
		$result = $out->strToConsole('Custom: %s');
		$this->assertIsString($result);
		$this->assertStringContainsString('Custom:', $result);
	}
}
